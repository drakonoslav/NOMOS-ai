{
  "name": "epistemic-ai-demo",
  "version": "0.1.0",
  "private": true,
  "description": "A tiny constitutional kernel demo for Epistemic AI",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/main.ts",
    "dev": "tsx watch src/main.ts",
    "start:ts-node": "ts-node src/main.ts",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "typescript",
    "control",
    "observer",
    "robustness",
    "epistemic-ai"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.13.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
