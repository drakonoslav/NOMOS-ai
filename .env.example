# NOMOS environment template
# Copy this to .env for local development only.
# In Replit, do NOT commit real secrets here.
# Put real values in Replit Secrets.

OPENAI_API_KEY=your_openai_api_key_here

# Optional: override the default model used by src/llm/openai_client.ts
OPENAI_MODEL=gpt-5.4

# Optional: set Node environment explicitly
NODE_ENV=development
