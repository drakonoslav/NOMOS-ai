{
  "name": "nomos-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "NOMOS — a constitutional system governing lawful action under reality.",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/main.ts",
    "start:ts-node": "node --loader ts-node/esm src/main.ts",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "test": "tsc --noEmit && tsx src/main.ts"
  },
  "dependencies": {
    "openai": "^4.56.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "@types/node": "^25.3.3"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
